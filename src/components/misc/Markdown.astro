---
import '@fontsource-variable/jetbrains-mono'
import '@fontsource-variable/jetbrains-mono/wght-italic.css'

interface Props {
  class: string
}
const className = Astro.props.class
---
<div data-pagefind-body class=`prose dark:prose-invert prose-base !max-w-none custom-md ${className}`>
    <!--<div class="prose dark:prose-invert max-w-none custom-md">-->
    <!--<div class="max-w-none custom-md">-->
    <slot/>
</div>

<script>
  let mermaidModulePromise: Promise<any> | null = null;

  function getMermaidModule() {
    if (!mermaidModulePromise) {
      // @ts-ignore mermaid types are not resolved in this inline script context
      mermaidModulePromise = import("mermaid");
    }
    return mermaidModulePromise;
  }

  async function renderMermaidBlocks(forceRerender = false) {
    const mermaidCodeBlocks = Array.from(
      document.querySelectorAll(
        'pre[data-language="mermaid"], pre > code.language-mermaid',
      ),
    );

    const mermaid = (await getMermaidModule()).default;
    const isDark = document.documentElement.classList.contains("dark");

    mermaid.initialize({
      startOnLoad: false,
      securityLevel: "strict",
      theme: "base",
      look: "handDrawn",
      themeVariables: {
        fontFamily:
          "Roboto, 'JetBrains Mono Variable', 'JetBrains Mono', system-ui, sans-serif",
        background: "transparent",
        primaryColor: isDark ? "#1f2937" : "#f8fafc",
        secondaryColor: isDark ? "#243447" : "#fef3c7",
        tertiaryColor: isDark ? "#2a2f45" : "#e0f2fe",
        primaryTextColor: isDark ? "#e5e7eb" : "#1f2937",
        primaryBorderColor: isDark ? "#93c5fd" : "#93c5fd",
        lineColor: isDark ? "#c4b5fd" : "#a78bfa",
        textColor: isDark ? "#f3f4f6" : "#374151",
        nodeBorder: isDark ? "#c4b5fd" : "#93c5fd",
        clusterBkg: isDark ? "#111827" : "#fdf4ff",
        clusterBorder: isDark ? "#a5b4fc" : "#c4b5fd",
        noteBkgColor: isDark ? "#1e293b" : "#fef9c3",
        noteTextColor: isDark ? "#f8fafc" : "#334155",
        actorBkg: isDark ? "#1f2937" : "#ecfeff",
        actorBorder: isDark ? "#67e8f9" : "#7dd3fc",
      },
    });

    for (const node of mermaidCodeBlocks) {
      const preElement =
        node instanceof HTMLPreElement ? node : node.closest("pre");
      if (!preElement) continue;
      if (preElement.dataset.mermaidRendered === "true") continue;

      const mermaidSource = preElement.textContent?.trim();
      if (!mermaidSource) continue;

      const wrapper = document.createElement("div");
      wrapper.className = "mermaid-wrapper";
      wrapper.dataset.mermaidRendered = "true";
      wrapper.dataset.mermaidSource = mermaidSource;

      const container = document.createElement("div");
      container.className = "mermaid";
      container.textContent = mermaidSource;
      wrapper.appendChild(container);

      preElement.replaceWith(wrapper);
    }

    const wrappers = Array.from(
      document.querySelectorAll<HTMLElement>(".mermaid-wrapper"),
    );
    if (wrappers.length === 0) return;

    if (forceRerender) {
      for (const wrapper of wrappers) {
        const source = wrapper.dataset.mermaidSource;
        if (!source) continue;
        wrapper.innerHTML = "";
        const container = document.createElement("div");
        container.className = "mermaid";
        container.textContent = source;
        wrapper.appendChild(container);
      }
    }

    await mermaid.run({ querySelector: ".mermaid-wrapper .mermaid" });
  }

  const observer = new MutationObserver(addPreCopyButton);
  observer.observe(document.body, { childList: true, subtree: true });
  
  async function applyMarkdownEnhancements() {
    await renderMermaidBlocks();
    addPreCopyButton();
  }

  document.addEventListener("DOMContentLoaded", applyMarkdownEnhancements);

  function addPreCopyButton() {
    observer.disconnect();
    
    let codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (let codeBlock of codeBlocks) {
      if (codeBlock.parentElement?.nodeName === "DIV" && codeBlock.parentElement?.classList.contains("code-block")) continue
      if (codeBlock.dataset.language === "mermaid") continue
      if (codeBlock.querySelector("code.language-mermaid")) continue

      let wrapper = document.createElement("div");
      wrapper.className = "relative code-block";

      let copyButton = document.createElement("button");
      copyButton.className = "copy-btn btn-regular-dark absolute active:scale-90 h-8 w-8 top-2 right-2 opacity-75 text-sm p-1.5 rounded-lg transition-all ease-in-out";

      codeBlock.setAttribute("tabindex", "0");
      if (codeBlock.parentNode) {
        codeBlock.parentNode.insertBefore(wrapper, codeBlock);
      }

      let copyIcon = `<svg class="copy-btn-icon copy-icon" xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960" width="20px"><path d="M368.37-237.37q-34.48 0-58.74-24.26-24.26-24.26-24.26-58.74v-474.26q0-34.48 24.26-58.74 24.26-24.26 58.74-24.26h378.26q34.48 0 58.74 24.26 24.26 24.26 24.26 58.74v474.26q0 34.48-24.26 58.74-24.26 24.26-58.74 24.26H368.37Zm0-83h378.26v-474.26H368.37v474.26Zm-155 238q-34.48 0-58.74-24.26-24.26-24.26-24.26-58.74v-515.76q0-17.45 11.96-29.48 11.97-12.02 29.33-12.02t29.54 12.02q12.17 12.03 12.17 29.48v515.76h419.76q17.45 0 29.48 11.96 12.02 11.97 12.02 29.33t-12.02 29.54q-12.03 12.17-29.48 12.17H213.37Zm155-238v-474.26 474.26Z"/></svg>`
      let successIcon = `<svg class="copy-btn-icon success-icon" xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960" width="20px"><path d="m389-377.13 294.7-294.7q12.58-12.67 29.52-12.67 16.93 0 29.61 12.67 12.67 12.68 12.67 29.53 0 16.86-12.28 29.14L419.07-288.41q-12.59 12.67-29.52 12.67-16.94 0-29.62-12.67L217.41-430.93q-12.67-12.68-12.79-29.45-.12-16.77 12.55-29.45 12.68-12.67 29.62-12.67 16.93 0 29.28 12.67L389-377.13Z"/></svg>`
      copyButton.innerHTML = `<div>${copyIcon} ${successIcon}</div>
      `

      wrapper.appendChild(codeBlock);
      wrapper.appendChild(copyButton);

      let timeout: ReturnType<typeof setTimeout>;
      copyButton.addEventListener("click", async () => {
        if (timeout) {
            clearTimeout(timeout);
        }
        let text = codeBlock?.querySelector("code")?.innerText;
        if (text === undefined) return;
        await navigator.clipboard.writeText(text);
        copyButton.classList.add("success");
        timeout = setTimeout(() => {
          copyButton.classList.remove("success");
        }, 1000);
      });
    }
    
    observer.observe(document.body, { childList: true, subtree: true });
  }

  function setupSwupMermaidRerender() {
    const rerender = () => {
      applyMarkdownEnhancements().catch((error) => {
        console.error("Failed to render Mermaid charts:", error);
      });
    };

    if (window?.swup?.hooks) {
      window.swup.hooks.on("page:view", rerender);
    } else {
      document.addEventListener("swup:enable", () => {
        window.swup?.hooks?.on("page:view", rerender);
      });
    }
  }

  function setupThemeMermaidRerender() {
    let timer: ReturnType<typeof setTimeout> | null = null;
    const themeObserver = new MutationObserver(() => {
      if (timer) clearTimeout(timer);
      timer = setTimeout(() => {
        renderMermaidBlocks(true).catch((error) => {
          console.error("Failed to re-render Mermaid charts for theme:", error);
        });
      }, 50);
    });

    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });
  }

  setupSwupMermaidRerender();
  setupThemeMermaidRerender();
</script>

<style is:global>
  .mermaid-wrapper {
    @apply my-6 overflow-x-auto rounded-lg border border-black/10 p-3 dark:border-white/10;
  }

  .mermaid-wrapper .mermaid {
    @apply mx-auto min-w-max;
  }
</style>
